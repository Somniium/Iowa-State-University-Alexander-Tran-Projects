<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    tools:context=".FakeFeedActivity"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:orientation="vertical">
    <TextView
        android:id="@+id/feed_header"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:gravity="center"
        android:textColor="#fc0303"
        android:textSize="50sp"
        />
    <ScrollView
        android:id="@+id/view_window"
        android:layout_width="match_parent"
        android:layout_height="400dp">

        <!--This would be a reusable fragment ideally, but I just learned about those and don't have time-->
        <LinearLayout
            android:id="@+id/post_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/fake_post_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/media_type"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:orientation="vertical"
                    android:src="@drawable/music_type"
                    android:contentDescription="music icon"/>

                <LinearLayout
                    android:layout_width="200dp"
                    android:layout_height="80dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/fake_post_1_username"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="edwincepeda_23"/>
                    <TextView
                        android:id="@+id/fake_post_1_worktitle"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="Bodies X, by: Thornhill"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/fake_post_1_rating"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:text="78"
                    android:gravity="center"
                    android:textSize="50sp"
                    android:textColor="#FFFFFF"
                    android:background="#9ACD32"/>

            </LinearLayout>

            <!--From here, these are just unformatted dummy posts.-->
            <TextView
                android:id="@+id/fake_post_2"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:text="I loved Viet Thanh Nguyen's The Sympathizer!"/>

            <TextView
                android:id="@+id/fake_post_3"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:text="Breaking Bad is a great show!" />

            <TextView
                android:id="@+id/fake_post_4"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:text="Media literacy is dead and we killed it..." />

            <TextView
                android:id="@+id/fake_post_5"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:text="The fitness gram pacer test is a multi-stage aerobic capacity test..."/>

            <TextView
                android:id="@+id/fake_post_6"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:text="Good Luck, Babe! by Chappell Roan is overrated."/>

            <TextView
                android:id="@+id/fake_post_7"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:text="Thornhill's 'BODIES' was my AOTY."/>

            <TextView
                android:id="@+id/fake_post_8"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:text="Nickleback is overhated and I will die on this hill."/>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:gravity="center">
        <Button
            android:id="@+id/logout_button"
            android:layout_width="100dp"
            android:layout_height="48dp"
            android:text="Logout"
            android:layout_gravity="center"
            android:backgroundTint="#fc0303"
            android:textColor="#FFFFFF"
            />
    </LinearLayout>
</androidx.appcompat.widget.LinearLayoutCompat>