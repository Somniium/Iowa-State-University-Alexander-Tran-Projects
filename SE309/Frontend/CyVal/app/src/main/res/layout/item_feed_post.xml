<?xml version="1.0" encoding="utf-8"?>
<!--
  item_feed_post.xml — Media cover-art card for the main feed (TYPE_MEDIA).
  Inflated by FeedAdapter.MediaViewHolder.

  Used for: ALBUM · BOOK · GAME · MOVIE · ARTIST cards interspersed in the feed.
  The outer CardView border is tinted by the community rating colour.
  The cover image (90×90 dp) is loaded asynchronously by ApiClient.loadImage().
  The rating badge overlays the bottom-right corner.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#848482">

    <!-- White inner surface — sits 5dp inside the tinted card border -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:background="@drawable/rounded_inner_bg">

        <!-- ── Cover image + text details ───────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:paddingEnd="60dp">

            <!-- Cover art: album artwork, book thumbnail, game box, movie poster, artist photo -->
            <ImageView
                android:id="@+id/feed_cover_img"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:scaleType="centerCrop"
                android:background="#E0E0E0" />

            <!-- Text column — vertically centred alongside the cover image -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:layout_gravity="center_vertical"
                android:orientation="vertical">

                <!-- Small-caps media type label, e.g. "ALBUM" -->
                <TextView
                    android:id="@+id/feed_media_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#888888"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <!-- Primary title — album name, book title, game title, etc. -->
                <TextView
                    android:id="@+id/feed_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp" />

                <!-- Subtitle — artist / author / director / developer -->
                <TextView
                    android:id="@+id/feed_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp" />

                <!-- Extra info — genre / release date -->
                <TextView
                    android:id="@+id/feed_extra_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </LinearLayout>

        <!-- ── Rating badge — overlays the bottom-right corner ──────────── -->
        <TextView
            android:id="@+id/feed_rating_badge"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="8dp"
            android:gravity="center"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/rating_badge_bg" />

    </FrameLayout>
</androidx.cardview.widget.CardView>
