<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    tools:context=".MainActivity"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical">

        <LinearLayout
            android:id="@+id/queryInterface"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/queryHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add or Manage Admins?"
                android:layout_gravity="center"
                android:layout_marginBottom="35dp"
                android:textSize="30dp"
                android:textColor="#fc0303">
            </TextView>
            <Button
                android:id="@+id/queryAddBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Add"
                android:textSize="20sp"
                android:textColor="#ffffff"
                android:backgroundTint="#fc0303">
            </Button>
            <Button
                android:id="@+id/queryManageBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Manage"
                android:textSize="20sp"
                android:textColor="#ffffff"
                android:backgroundTint="#fc0303">
            </Button>

        </LinearLayout>


        <LinearLayout
            android:id="@+id/addInterface"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/userAddEdt"
                android:layout_width="300dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:hint="Enter User's ID here"/>

            <Button
                android:id="@+id/addBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Promote User to Admin"
                android:textSize="20sp"
                android:textColor="#ffffff"
                android:backgroundTint="#fc0303">
            </Button>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/manageInterface"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/login_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage Admin"
                android:layout_gravity="center"
                android:layout_marginBottom="35dp"
                android:textSize="30dp"
                android:textColor="#fc0303">
            </TextView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">
                <EditText
                    android:id="@+id/userEdt"
                    android:layout_width="300dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:hint="Find Admin by ADMIN ID (NOT USER ID)">
                </EditText>
                <ImageButton
                    android:id="@+id/searchBtn"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/search_icon"/>
            </LinearLayout>


                <TextView
                    android:id="@+id/adminIdText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin ID: "
                    android:textSize="20dp"
                    android:textColor="#000000">
                </TextView>


                <TextView
                    android:id="@+id/userIdText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User ID: "
                    android:textSize="20dp"
                    android:textColor="#000000">
                </TextView>

                <TextView
                    android:id="@+id/masterText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Master: "
                    android:textSize="20dp"
                    android:textColor="#000000">
                </TextView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center"
                android:layout_marginTop="30dp">

                <Button
                    android:id="@+id/promoteBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Promote to Master"
                    android:textSize="20sp"
                    android:textColor="#ffffff"
                    android:backgroundTint="#fc0303">
                </Button>

                <Button
                    android:id="@+id/deleteBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Delete Admin"
                    android:textSize="20sp"
                    android:textColor="#ffffff"
                    android:backgroundTint="#fc0303">
                </Button>

        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/returnBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Back to Dashboard"
        android:textSize="20sp"
        android:textColor="#ffffff"
        android:backgroundTint="#fc0303">
    </Button>

</androidx.appcompat.widget.LinearLayoutCompat>