<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/rounded_inner_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E53935"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/create_post_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:src="@drawable/ic_back"
            android:visibility="gone" />

        <TextView
            android:id="@+id/create_post_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Select media"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginStart="4dp" />

        <ImageView
            android:id="@+id/create_post_close"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <!-- Search Phase -->
    <LinearLayout
        android:id="@+id/search_phase"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Filter chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chip_all"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="All"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/media_type_chip_bg"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/chip_music"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Music"
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:background="@drawable/comment_input_bg"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/chip_games"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Games"
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:background="@drawable/comment_input_bg"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/chip_movies"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Movies"
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:background="@drawable/comment_input_bg"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/chip_shows"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Shows"
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:background="@drawable/comment_input_bg"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/chip_books"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Books"
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:background="@drawable/comment_input_bg" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Search bar -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="22dp"
            app:cardBackgroundColor="#F0F0F0"
            app:cardElevation="0dp">

            <EditText
                android:id="@+id/search_input"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:hint="Search..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:textSize="13sp" />
        </androidx.cardview.widget.CardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/search_results_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- Review Phase -->
    <ScrollView
        android:id="@+id/review_phase"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Selected media -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/comment_input_bg"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">

                <ImageView
                    android:id="@+id/selected_media_cover"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/cyval_logo" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/selected_media_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#000000"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/selected_media_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#888888" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rating (0-100)"
                android:textSize="12sp"
                android:textColor="#000000"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <EditText
                android:id="@+id/review_rating"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:inputType="number"
                android:textColor="#000000"
                android:hint="0"
                android:textColorHint="#888888"
                android:background="@drawable/comment_input_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Review"
                android:textSize="12sp"
                android:textColor="#000000"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <EditText
                android:id="@+id/review_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="3"
                android:inputType="textMultiLine"
                android:textColor="#000000"
                android:hint="Write your review..."
                android:textColorHint="#888888"
                android:background="@drawable/comment_input_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:gravity="top"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Caption"
                android:textSize="12sp"
                android:textColor="#000000"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <EditText
                android:id="@+id/review_caption"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:inputType="text"
                android:textColor="#000000"
                android:hint="Required"
                android:textColorHint="#888888"
                android:background="@drawable/comment_input_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btn_publish"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:text="Publish"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:backgroundTint="#E53935"
                app:cornerRadius="8dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>