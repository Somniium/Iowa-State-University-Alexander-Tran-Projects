<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:background="#FFFFFF">

    <!-- Simple colored dot — visible for unread, GONE for read -->
    <View
        android:id="@+id/notif_unread_indicator"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/media_type_chip_bg"
        android:backgroundTint="#E53935"
        android:layout_marginEnd="12dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notif_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#000000"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/notif_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#888888" />
    </LinearLayout>

    <TextView
        android:id="@+id/notif_type_badge"
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:textSize="9sp"
        android:textColor="#FFFFFF"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:background="@drawable/media_type_chip_bg"
        android:layout_marginStart="10dp"/>

</LinearLayout>