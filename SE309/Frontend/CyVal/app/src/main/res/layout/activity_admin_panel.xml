<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    tools:context=".MainActivity"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textSize="30sp"
        android:layout_marginBottom="20dp"
        android:text="Administrator Dashboard"/>

    <LinearLayout
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_marginBottom="40dp">

        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="25sp"
            android:text="Manage Users"
            android:gravity="center"/>

        <LinearLayout
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:gravity="center">

            <Button android:id="@+id/btnUserManage"
                android:layout_width="120dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:text="All Users"
                android:backgroundTint="#ff0000"/>

            <Button android:id="@+id/btnProfessorManage"
                android:layout_width="120dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:text="Professors"
                android:backgroundTint="#ff0000"/>

            <Button android:id="@+id/btnAdminManage"
                android:layout_width="120dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:text="Admins"
                android:backgroundTint="#ff0000"/>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_marginBottom="40dp">

        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="25sp"
            android:text="Manage Posts and Groups"
            android:gravity="center"/>

        <LinearLayout
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:gravity="center">

            <Button android:id="@+id/btnReviewManage"
                android:layout_width="120dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:text="Reviews"
                android:backgroundTint="#ff0000"/>

            <Button android:id="@+id/btnCommentsRepliesManage"
                android:layout_width="120dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:text="Comments\nReplies"
                android:backgroundTint="#ff0000"/>

            <Button android:id="@+id/btnGroupsManage"
                android:layout_width="120dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:text="Groups"
                android:backgroundTint="#ff0000"/>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_marginBottom="40dp">

        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="25sp"
            android:text="Manage Media Data"
            android:gravity="center"/>

        <LinearLayout
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:gravity="center">

            <Button android:id="@+id/btnAlbumManage"
                android:layout_width="120dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:text="Albums"
                android:backgroundTint="#ff0000"/>

            <Button android:id="@+id/btnArtistManage"
                android:layout_width="120dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:text="Artists"
                android:backgroundTint="#ff0000"/>

            <Button android:id="@+id/btnBookManage"
                android:layout_width="120dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:text="Books"
                android:backgroundTint="#ff0000"/>
        </LinearLayout>

        <LinearLayout
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:gravity="center">
            <Button android:id="@+id/btnGameManage"
                android:layout_width="120dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:text="Games"
                android:backgroundTint="#ff0000"/>

            <Button android:id="@+id/btnMovieManage"
                android:layout_width="120dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:text="Movies\nShows"
                android:backgroundTint="#ff0000"/>
        </LinearLayout>
    </LinearLayout>

    <Button android:id="@+id/btnReturn"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:layout_marginBottom="20dp"
        android:layout_gravity="center"
        android:text="Return"
        android:backgroundTint="#ff0000"/>

</androidx.appcompat.widget.LinearLayoutCompat>