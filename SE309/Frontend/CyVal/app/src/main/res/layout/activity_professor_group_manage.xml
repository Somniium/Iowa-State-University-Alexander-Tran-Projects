<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    tools:context=".MainActivity"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical">

        <TextView
            android:id="@+id/header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage Or Access"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:textSize="25sp"
            android:textColor="#fc0303">
        </TextView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="vertical"
        android:elevation="2dp">

    <TextView
        android:id="@+id/group_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#000000"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:text="[PLACEHOLDER NAME]"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/group_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#555555"
                android:textSize="14sp"
                android:text="Group ID: "/>

            <TextView
                android:id="@+id/id_separator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#999999"
                android:textSize="14sp"
                android:text=" - "/>

            <TextView
                android:id="@+id/professor_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#555555"
                android:textSize="14sp"
                android:text="Prof ID: "/>
        </LinearLayout>

        <Button
            android:id="@+id/access_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Go to Group's Chat"
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:backgroundTint="#fc0303">
        </Button>
    </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:layout_marginLeft="30dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Group Name: "
                android:textSize="16dp"
                android:textColor="#000000">
            </TextView>

            <EditText
                android:id="@+id/group_name_input"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:textSize="16sp"
                android:hint="Enter Group Name">
            </EditText>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:layout_marginLeft="30dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Group Class: "
                android:textSize="16sp"
                android:textColor="#000000">
            </TextView>

            <EditText
                android:id="@+id/group_class_input"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:textSize="16sp"
                android:hint="Enter Class Name">
            </EditText>

        </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <TextView
        android:id="@+id/students_subheader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#FF0000"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:gravity="center"
        android:text="Student Manager"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="horizontal">

        <ListView
            android:id="@+id/students_list"
            android:layout_width="200dp"
            android:layout_height="200dp">
        </ListView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="17sp"
                android:text="Add/Remove Student"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Student Name:"/>
            <EditText
                android:id="@+id/student_name_input"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center"
                android:hint="Student Username"/>

            <Button
                android:id="@+id/student_add_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add"
                android:backgroundTint="#FF0000"/>
            <Button
                android:id="@+id/student_remove_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Remove"
                android:backgroundTint="#FF0000"/>
        </LinearLayout>

    </LinearLayout>
    </LinearLayout>


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center">
            <Button
                android:id="@+id/update_group_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Update Group"
                android:textSize="16sp"
                android:textColor="#ffffff"
                android:backgroundTint="#fc0303"
                android:layout_marginEnd="20dp">
            </Button>

            <Button
                android:id="@+id/delete_group_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Delete Group"
                android:textSize="16sp"
                android:textColor="#ffffff"
                android:backgroundTint="#fc0303">
            </Button>
        </LinearLayout>

        <Button
            android:id="@+id/return_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Back to Dashboard"
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:backgroundTint="#fc0303">
        </Button>
    </LinearLayout>



</LinearLayout>