<?xml version="1.0" encoding="utf-8"?>
<!--
  item_feed_user_post.xml — Post card for the main feed (TYPE_POST).
  Inflated by FeedAdapter.PostViewHolder.

  The outer CardView border is tinted by the rating colour.
  The inner FrameLayout stays white via rounded_inner_bg.
  The rating badge overlays the bottom-right corner.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#848482">

    <!-- White inner surface — sits 5dp inside the tinted card border -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:background="@drawable/rounded_inner_bg">

        <!-- ── Main content column ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Author row: avatar · name · media type · timestamp -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <!-- Circular avatar — background colour set programmatically -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/feed_author_avatar"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#E0E0E0">

                    <TextView
                        android:id="@+id/feed_author_initial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/feed_author_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textSize="13sp"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:text="·"
                    android:textSize="13sp"
                    android:textColor="#000000" />

                <!-- Media type label, e.g. "ALBUM" -->
                <TextView
                    android:id="@+id/feed_media_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#000000"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:text="·"
                    android:textSize="13sp"
                    android:textColor="#000000" />

                <!-- Relative timestamp, e.g. "3h" or "2d" -->
                <TextView
                    android:id="@+id/feed_timestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#000000" />
            </LinearLayout>

            <!-- Media title — padded on the end to clear the rating badge overlay -->
            <TextView
                android:id="@+id/feed_media_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingEnd="55dp"
                android:textSize="17sp"
                android:textColor="#000000"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <!-- Caption — hidden (GONE) when the user left it blank -->
            <TextView
                android:id="@+id/feed_caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingEnd="55dp"
                android:textSize="14sp"
                android:textColor="#000000"
                android:maxLines="3"
                android:ellipsize="end"
                android:layout_marginBottom="10dp" />

            <!-- Social counters: animated like button + counts -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Animated heart from jd-alexander/LikeButton -->
                <com.like.LikeButton
                    android:id="@+id/feed_like_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon_type="heart"
                    app:icon_size="14dp"
                    app:circle_start_color="#E53935"
                    app:circle_end_color="#E91E63"
                    app:dots_primary_color="#E53935"
                    app:dots_secondary_color="#FF4081" />

                <TextView
                    android:id="@+id/feed_like_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#000000"
                    android:layout_marginStart="2dp" />

                <TextView
                    android:id="@+id/feed_comment_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:textSize="13sp"
                    android:textColor="#000000" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── Rating badge — overlays the bottom-right corner ──────────── -->
        <TextView
            android:id="@+id/feed_rating_badge"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="8dp"
            android:gravity="center"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/rating_badge_bg" />

    </FrameLayout>
</androidx.cardview.widget.CardView>
