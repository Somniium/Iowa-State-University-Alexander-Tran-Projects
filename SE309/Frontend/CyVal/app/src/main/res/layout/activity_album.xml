<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E53935"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="25dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="2dp">

            <EditText
                android:id="@+id/search_bar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@android:color/transparent"
                android:hint="Search for an album..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:textColor="#000000"
                android:textColorHint="#888888" />
        </androidx.cardview.widget.CardView>
    </androidx.appcompat.widget.LinearLayoutCompat>

    <TextView
        android:id="@+id/temp_txt"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="search for an album!"
        android:textSize="20sp"
        android:textColor="#000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/album_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone"
            android:padding="16dp"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/name_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:textColor="#000000"
                android:layout_marginBottom="12dp"/>

            <ImageView
                android:id="@+id/cover_img"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:scaleType="centerCrop"
                android:background="#CCCCCC"/>

            <TextView
                android:id="@+id/artist_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textColor="#000000"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/release_date_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="#000000"/>

            <TextView
                android:id="@+id/genre_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="#000000"
                android:layout_marginBottom="24dp"/>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rating: "
                    android:textSize="28sp"
                    android:textColor="#000000"
                    android:layout_marginEnd="16dp"/>

                <TextView
                    android:id="@+id/rating_txt"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:background="#CCCCCC"
                    android:textSize="45sp"
                    android:textColor="#000000"
                    android:gravity="center"/>
            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="32dp">

                <EditText
                    android:id="@+id/review_rating_input"
                    android:layout_width="100dp"
                    android:layout_height="50dp"
                    android:background="#F5F5F5"
                    android:textColor="#000000"
                    android:gravity="center"
                    android:hint="0-100"
                    android:textColorHint="#888888"
                    android:inputType="number"
                    android:layout_marginEnd="16dp"
                    android:elevation="2dp" />

                <Button
                    android:id="@+id/btn_submit_score"
                    android:layout_width="160dp"
                    android:layout_height="50dp"
                    android:backgroundTint="#01C523"
                    android:textColor="#FFFFFF"
                    android:text="Submit Score"
                    android:textAllCaps="false" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <Button
                android:id="@+id/btn_delete_album"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#FF0000"
                android:textColor="#FFFFFF"
                android:text="Delete Album &amp; Reviews"
                android:textAllCaps="false"
                app:cornerRadius="25dp"/>

        </androidx.appcompat.widget.LinearLayoutCompat>
    </ScrollView>
</androidx.appcompat.widget.LinearLayoutCompat>