<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_view_profile.xml

  Root is a vertical LinearLayout so the red header (with the back button)
  stays FIXED at the top while the NestedScrollView below scrolls freely.

  RecyclerView sits inside the NestedScrollView with
  nestedScrollingEnabled="false" so ALL posts are laid out (the outer
  NestedScrollView handles the single unified scroll gesture).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8"
    android:orientation="vertical">

    <!-- ── Red header — FIXED, never scrolls ─────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#E53935"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_back"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/view_profile_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Spacer to balance the back-button on the left -->
        <View
            android:layout_width="40dp"
            android:layout_height="28dp" />
    </LinearLayout>

    <!-- ── Scrollable content area ────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:elevation="2dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#E0E0E0"
                    app:cardCornerRadius="40dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:padding="16dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="#757575" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/view_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <!-- Major: view + edit -->
                <TextView
                    android:id="@+id/view_profile_major"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#444444"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/edit_major"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:hint="Major"
                    android:inputType="text"
                    android:gravity="center"
                    android:textColor="#444444"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/view_profile_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <!-- Bio: view + edit -->
                <TextView
                    android:id="@+id/view_profile_bio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingHorizontal="24dp"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/edit_bio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Bio"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:gravity="center"
                    android:paddingHorizontal="24dp"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone" />

                <!-- Edit / Save button — only shown for own profile -->
                <Button
                    android:id="@+id/btn_edit_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:backgroundTint="#E53935"
                    android:text="Edit Profile"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:paddingHorizontal="24dp"
                    android:visibility="gone"
                    app:cornerRadius="20dp" />
            </LinearLayout>

            <!-- Detail cards + posts -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_hobbies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/view_profile_hobbies"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#333333"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/edit_hobbies"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Hobbies"
                            android:inputType="text"
                            android:textColor="#333333"
                            android:textSize="16sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_grad_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/view_profile_grad_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#333333"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/edit_grad_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Graduation Date"
                            android:inputType="text"
                            android:textColor="#333333"
                            android:textSize="16sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_linkedin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/view_profile_linkedin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#0077B5"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/edit_linkedin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="LinkedIn URL"
                            android:inputType="textUri"
                            android:textColor="#0077B5"
                            android:textSize="16sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Empty state — shown when no profile fields are set -->
                <TextView
                    android:id="@+id/view_profile_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingTop="16dp"
                    android:text="This user hasn't set up their profile yet."
                    android:textColor="#999999"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <!-- ── Posts section ─────────────────────────────────────── -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp"
                    android:background="#E0E0E0" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp"
                    android:text="Posts"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!--
                  nestedScrollingEnabled="false" lets the NestedScrollView above
                  own the single scroll gesture, so this RecyclerView expands to
                  its full height and shows every post.
                -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/profile_posts_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/profile_posts_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:text="No posts yet."
                    android:textColor="#999999"
                    android:textSize="14sp"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
